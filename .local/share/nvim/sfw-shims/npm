#!/bin/sh

shim_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

clean_path=
old_ifs=$IFS
IFS=:
for p in $PATH; do
  [ "$p" = "$shim_dir" ] && continue
  clean_path="${clean_path:+$clean_path:}$p"
done
IFS=$old_ifs

PATH=$clean_path

case "$1:$2" in
  install:*|i:*|ci:*|update:*|up:*|upgrade:*|exec:*|x:*|create:*|init:*|install-test:*|it:*|audit:fix|-g:install|-g:i|-g:update|-g:upgrade)
    exec sfw npm "$@"
    ;;
  *)
    exec npm "$@"
    ;;
esac
