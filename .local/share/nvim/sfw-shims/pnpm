#!/bin/sh

shim_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

clean_path=
old_ifs=$IFS
IFS=:
for p in $PATH; do
  [ "$p" = "$shim_dir" ] && continue
  clean_path="${clean_path:+$clean_path:}$p"
done
IFS=$old_ifs

PATH=$clean_path

case "$1:$2" in
  add:*|install:*|i:*|upgrade:*|update:*|up:*|dlx:*|exec:*|create:*|import:*|fetch:*|patch:*|rebuild:*|link:*|-g:add|-g:install|-g:i|-g:upgrade|-g:update)
    exec sfw pnpm "$@"
    ;;
  *)
    exec pnpm "$@"
    ;;
esac
